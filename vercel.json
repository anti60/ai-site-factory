{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "ai-site-factory",
  "buildCommand": null,
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-site-factory.onrender.com/api/:path*"
    },
    {
      "source": "/generated/:path*",
      "destination": "https://ai-site-factory.onrender.com/generated/:path*"
    }
  ]
}
